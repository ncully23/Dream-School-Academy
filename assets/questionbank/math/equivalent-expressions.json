      "difficulty": "easy",
      "answerType": "mcq",
      "prompt": "Which expression is equivalent to \\((x+4)(x-4)\\)?",
      "choices": ["x^2-16", "x^2+16", "x^2-8x", "x^2+8x"],
      "answerIndex": 0,
      "explanation": "This is a difference of squares: \\((a+b)(a-b)=a^2-b^2\\). Here, \\(x^2-4^2=x^2-16\\)."
    },
