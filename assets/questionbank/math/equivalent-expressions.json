      "prompt": "Which expression is equivalent to \\(5x+10+3(x-2)\\)?",
      "choices": ["8x+4", "8x+10", "8x-4", "5x+4"],
      "answerIndex": 0,
      "explanation": "Distribute: \\(3(x-2)=3x-6\\). Combine like terms: \\(5x+3x+10-6=8x+4\\)."
    },
