      "difficulty": "medium",
      "answerType": "mcq",
      "prompt": "Which expression is equivalent to \\(3(2x-5)-4x\\)?",
      "choices": ["2x-15", "6x-15", "2x-5", "6x-5"],
      "answerIndex": 0,
      "explanation": "Distribute first: \\(3(2x-5)=6x-15\\). Then subtract \\(4x\\): \\(6x-4x-15=2x-15\\)."
    },
