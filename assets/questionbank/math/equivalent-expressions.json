{
  "quizId": "math.equivalent.expressions.set1",
  "title": "Equivalent Expressions — Set 1",
  "section": "Math",
  "domain": "Algebra",
  "skill": "Equivalent expressions",
  "questions": [
    {
      "id": "ee01",
      "prompt": "Which expression is equivalent to 3(2x − 5) − 4x?",
      "choices": {
        "A": "2x − 15",
        "B": "6x − 15",
        "C": "2x − 5",
        "D": "6x − 5"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Distribute: 3(2x − 5) = 6x − 15. Subtract 4x to get 2x − 15."
    },
    {
      "id": "ee02",
      "prompt": "Which expression is equivalent to (x + 4)(x − 4)?",
      "choices": {
        "A": "x² − 16",
        "B": "x² + 16",
        "C": "x² − 8x",
        "D": "x² + 8x"
      },
      "correct": "A",
      "difficulty": "easy",
      "rationale": "This is a difference of squares: (a + b)(a − b) = a² − b²."
    },
    {
      "id": "ee03",
      "prompt": "Which expression is equivalent to 5x + 10 + 3(x − 2)?",
      "choices": {
        "A": "8x + 4",
        "B": "8x + 10",
        "C": "8x − 4",
        "D": "5x + 4"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Distribute: 3(x − 2) = 3x − 6. Combine terms: 5x + 3x + 10 − 6 = 8x + 4."
    },
    {
      "id": "ee04",
      "prompt": "Which expression is equivalent to 4x² − 12x?",
      "choices": {
        "A": "4x(x − 3)",
        "B": "x(4x − 12)",
        "C": "4(x² − 3)",
        "D": "x²(4 − 12)"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Factor out the greatest common factor, 4x: 4x(x − 3)."
    },
    {
      "id": "ee05",
      "prompt": "If a = x − 2, which expression is equivalent to a² + 4a?",
      "choices": {
        "A": "x² − 4",
        "B": "x² − 4x",
        "C": "x² − 8",
        "D": "x² − 4x + 4"
      },
      "correct": "A",
      "difficulty": "hard",
      "rationale": "Substitute a = x − 2: (x − 2)² + 4(x − 2) = x² − 4x + 4 + 4x − 8 = x² − 4."
    },
    {
      "id": "ee06",
      "prompt": "Which expression is equivalent to 2x(3x − 5) − x(3x − 5)?",
      "choices": {
        "A": "x(3x − 5)",
        "B": "5x",
        "C": "3x² − 5",
        "D": "x² − 5x"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Factor out the common term (3x − 5): (2x − x)(3x − 5) = x(3x − 5)."
    },
    {
      "id": "ee07",
      "prompt": "Which expression is equivalent to (x + 6)² − 36?",
      "choices": {
        "A": "x² + 12x",
        "B": "x² + 36",
        "C": "x(x + 12)",
        "D": "x² − 12x"
      },
      "correct": "A",
      "difficulty": "hard",
      "rationale": "(x + 6)² = x² + 12x + 36. Subtracting 36 gives x² + 12x."
    },
    {
      "id": "ee08",
      "prompt": "Which expression is equivalent to 7x − 14 + 3(2 − x)?",
      "choices": {
        "A": "4x − 8",
        "B": "10x − 8",
        "C": "4x − 20",
        "D": "x − 8"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Distribute: 3(2 − x) = 6 − 3x. Combine: 7x − 3x − 14 + 6 = 4x − 8."
    },
    {
      "id": "ee09",
      "prompt": "Which expression is equivalent to (x − 3)(x + 5) − x?",
      "choices": {
        "A": "x² + x − 15",
        "B": "x² + 2x − 15",
        "C": "x² − 15",
        "D": "x² − x − 15"
      },
      "correct": "A",
      "difficulty": "hard",
      "rationale": "Expand: (x − 3)(x + 5) = x² + 2x − 15. Subtract x to get x² + x − 15."
    },
    {
      "id": "ee10",
      "prompt": "Which expression is equivalent to (x/2)(4x − 6)?",
      "choices": {
        "A": "2x² − 3x",
        "B": "4x² − 6x",
        "C": "2x² − 6",
        "D": "x² − 3x"
      },
      "correct": "A",
      "difficulty": "medium",
      "rationale": "Distribute: (x/2)·4x = 2x² and (x/2)·(−6) = −3x."
    }
  ]
}
