      "difficulty": "hard",
      "answerType": "mcq",
      "prompt": "A ladder leans against a wall making a \\(60^\\circ\\) angle with the ground. If the ladder is \\(12\\) feet long, how far up the wall does the ladder reach?",
      "choices": ["6", "6\\sqrt{3}", "12\\sqrt{3}", "18"],
      "answerIndex": 1,
      "explanation": "Height \\(=12\\sin60^\\circ=6\\sqrt{3}\\)."
