    {
      "questionId": "SAT-rtt03",
      "topic": "math.right-triangles-trigonometry",
      "skill": "convert-sin-to-cos",
      "difficulty": "hard",
      "answerType": "mcq",
      "prompt": "In a right triangle, \\(\\sin \\theta = \\frac{3}{5}\\), where \\(\\theta\\) is acute. What is \\(\\cos \\theta\\)?",
      "choices": ["3/4", "4/5", "5/3", "\\sqrt{1-(3/5)^2}"],
      "answerIndex": 1,
      "explanation": "Opposite \\(=3\\), hypotenuse \\(=5\\), adjacent \\(=4\\). Thus \\(\\cos\\theta=\\frac{4}{5}\\)."
    },
    {
      "questionId": "SAT-rtt04",
      "topic": "math.right-triangles-trigonometry",
      "skill": "convert-tan-to-sin",
      "difficulty": "hard",
      "answerType": "mcq",
      "prompt": "If \\(\\tan \\theta = \\frac{7}{24}\\), what is \\(\\sin \\theta\\)?",
      "choices": ["7/25", "24/25", "7/24", "24/7"],
      "answerIndex": 0,
      "explanation": "Hypotenuse \\(=25\\), so \\(\\sin\\theta=\\frac{7}{25}\\)."
    },
    {
      "questionId": "SAT-rtt05",
      "topic": "math.right-triangles-trigonometry",
      "skill": "sine-from-legs",
      "difficulty": "hard",
      "answerType": "mcq",
      "prompt": "A right triangle has legs of length \\(9\\) and \\(12\\). What is \\(\\sin \\theta\\) opposite the side of length \\(9\\)?",
      "choices": ["3/5", "4/5", "9/12", "12/15"],
      "answerIndex": 0,
      "explanation": "Hypotenuse \\(=15\\). So \\(\\sin\\theta=\\frac{9}{15}=\\frac{3}{5}\\)."
    },
