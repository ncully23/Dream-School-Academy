      "topic": "math.circles",
      "skill": "sector-area",
      "difficulty": "medium",
      "prompt": "A sector of a circle with radius 8 has area 16π. What is the central angle of the sector in radians?",
      "promptHtml": null,
      "choices": ["π/4", "π/2", "π", "2π"],
      "answerIndex": 1,
      "solution": {
        "finalAnswer": "π/2",
        "approach": "Use A = (1/2)r²θ and solve for θ.",
        "steps": [
          "A = (1/2)r²θ = (1/2)(64)θ = 32θ.",
          "32θ = 16π → θ = (16π)/32 = π/2."
        ],
        "commonMistakes": [
          "Forgetting the 1/2 factor.",
          "Using πr²θ (incorrect).",
          "Cancelling π incorrectly."
        ],
        "checks": [
          "θ = π/2 is 1/4 of a circle; 1/4 of 64π is 16π ✓"
        ]
      }
    },
