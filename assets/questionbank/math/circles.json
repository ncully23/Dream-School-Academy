      "questionId": "math.circles.001",
      "version": 1,
      "topic": "math.circles",
      "skill": "circumference",
      "difficulty": "easy",
      "prompt": "A circle has radius 5 cm. What is its circumference?",
      "promptHtml": null,
      "choices": ["10π cm", "25π cm", "5π cm", "50π cm"],
      "answerIndex": 0,
      "solution": {
        "finalAnswer": "10π cm",
        "approach": "Use the circumference formula.",
        "steps": [
          "Use C = 2πr.",
          "Substitute r = 5: C = 2π(5).",
          "Simplify: C = 10π."
        ],
        "commonMistakes": [
          "Using the area formula A = πr² instead of circumference.",
          "Forgetting the factor of 2 in C = 2πr.",
          "Plugging in diameter when the problem gives radius."
        ],
        "checks": [
          "Units should be centimeters (cm), not cm².",
          "Circumference should be proportional to r; doubling r would double C."
        ]
      }
    },
    {
      "questionId": "math.circles.002",
      "version": 1,
      "topic": "math.circles",
      "skill": "area",
      "difficulty": "easy",
      "prompt": "If a circle’s area is 49π, what is its radius?",
      "promptHtml": null,
      "choices": ["3", "7", "14", "24.5"],
      "answerIndex": 1,
      "solution": {
        "finalAnswer": "7",
        "approach": "Solve the area equation for r.",
        "steps": [
          "Use A = πr².",
          "Set πr² = 49π.",
          "Divide both sides by π: r² = 49.",
          "Take the positive square root: r = 7."
        ],
        "commonMistakes": [
          "Forgetting to divide by π first.",
          "Taking r = −7 (radius is nonnegative).",
          "Treating 49π as 49 and ignoring π."
        ],
        "checks": [
          "Plug back in: π(7²) = 49π.",
          "Radius is a length, so it should not include π."
        ]
      }
    },
    {
      "questionId": "math.circles.003",
      "version": 1,
      "topic": "math.circles",
      "skill": "equation-of-a-circle",
      "difficulty": "medium",
      "prompt": "A circle passes through (0, 0) and (0, 6) with center at (0, 3). What is its equation?",
      "promptHtml": null,
      "choices": [
        "(x - 0)² + (y - 3)² = 9",
        "(x - 3)² + (y - 0)² = 9",
        "(x - 3)² + (y - 3)² = 6",
        "(x - 0)² + (y - 6)² = 3"
      ],
      "answerIndex": 0,
      "solution": {
        "finalAnswer": "(x - 0)² + (y - 3)² = 9",
        "approach": "Find r from the center to a point, then use standard form.",
        "steps": [
          "Center is (h, k) = (0, 3).",
          "Radius is the distance from (0, 3) to (0, 0): r = 3.",
          "Use (x - h)² + (y - k)² = r².",
          "Substitute h = 0, k = 3, r² = 9 → (x - 0)² + (y - 3)² = 9."
        ],
        "commonMistakes": [
          "Using r = 6 (confusing diameter with radius).",
          "Mixing up h and k in (x - h)² + (y - k)².",
          "Forgetting to square the radius on the right side."
        ],
        "checks": [
          "Test (0,0): 0 + (−3)² = 9 ✓",
          "Test (0,6): 0 + 3² = 9 ✓"
        ]
      }
    },
    {
      "questionId": "math.circles.004",
      "version": 1,
      "topic": "math.circles",
      "skill": "arc-length",
      "difficulty": "easy",
      "prompt": "For a circle with radius r = 10 and central angle θ = π/3 (in radians), what is the arc length s?",
      "promptHtml": null,
      "choices": ["10π/3", "20π/3", "30π", "10", "π/3"],
      "answerIndex": 0,
      "solution": {
        "finalAnswer": "10π/3",
        "approach": "Use s = rθ with θ in radians.",
        "steps": [
          "Use s = rθ (θ must be in radians).",
          "Substitute r = 10 and θ = π/3.",
          "Compute: s = 10 · (π/3) = 10π/3."
        ],
        "commonMistakes": [
          "Using degrees without converting (not needed here).",
          "Using circumference fraction incorrectly.",
          "Multiplying by 2π again (double-counting)."
        ],
        "checks": [
          "θ = π/3 is 1/6 of a circle, so s should be (1/6)(2πr) = (1/6)(20π) = 10π/3."
        ]
      }
    },
    {
      "questionId": "math.circles.005",
      "version": 1,
      "topic": "math.circles",
      "skill": "sector-area",
      "difficulty": "medium",
      "prompt": "What is the area of a sector of a circle with radius 6 and central angle θ = π/2?",
      "promptHtml": null,
      "choices": ["9π", "18π", "36π", "3π"],
      "answerIndex": 0,
      "solution": {
        "finalAnswer": "9π",
        "approach": "Use sector area with radians.",
        "steps": [
          "Full area is πr² = π(6²) = 36π.",
          "θ = π/2 corresponds to a fraction θ/(2π) = (π/2)/(2π) = 1/4 of the circle.",
          "Sector area = (1/4)(36π) = 9π."
        ],
        "commonMistakes": [
          "Arithmetic slip when multiplying by θ.",
          "Assuming θ = π/2 is half the circle (it’s a quarter).",
          "Forgetting the θ/(2π) fraction method."
        ],
        "checks": [
          "90° is 1/4 of a circle, so area must be 1/4 of 36π = 9π."
        ]
      }
    },
