    {
      "questionId": "math.circles.008",
      "version": 1,
      "topic": "math.circles",
      "skill": "equation-of-a-circle",
      "difficulty": "easy",
      "prompt": "Which equation represents a circle with center (-2, 4) and radius 5?",
      "promptHtml": null,
      "choices": [
        "(x - 2)² + (y - 4)² = 25",
        "(x + 2)² + (y - 4)² = 25",
        "(x + 2)² + (y + 4)² = 25",
        "(x - 2)² + (y + 4)² = 25"
      ],
      "answerIndex": 1,
      "solution": {
        "finalAnswer": "(x + 2)² + (y - 4)² = 25",
        "approach": "Use (x - h)² + (y - k)² = r².",
        "steps": [
          "h = −2 → (x - (−2))² = (x + 2)².",
          "k = 4 → (y - 4)².",
          "r² = 25.",
          "So (x + 2)² + (y - 4)² = 25."
        ],
        "commonMistakes": [
          "Using (x - 2) instead of (x + 2).",
          "Using r = 25 instead of r² = 25.",
          "Flipping the sign on k."
        ],
        "checks": [
          "Center shift left 2 → (x + 2). Up 4 → (y - 4)."
        ]
      }
    },
    {
      "questionId": "math.circles.009",
